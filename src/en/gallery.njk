---
layout: layouts/base.njk
lang: en
title: "Photo Gallery — Pomsky, Pomeranian & Husky — Cimes Blanches Kennel"
description: "30 photos of our Pomsky, Pomeranian and Siberian Husky puppies and adults. Life at Cimes Blanches Kennel in Sierre, Valais Switzerland."
permalink: "/en/gallery.html"
hreflang_fr: "/galerie.html"
hreflang_en: "/en/gallery.html"
---
<style>
.gallery-filters{display:flex;gap:.8rem;margin-bottom:2.5rem;flex-wrap:wrap}
.filter-btn{padding:.5rem 1.2rem;font-family:var(--sans);font-size:.72rem;letter-spacing:.12em;text-transform:uppercase;border:1px solid var(--gris-clair);border-radius:20px;background:transparent;color:var(--gris);cursor:pointer;transition:all .2s}
.filter-btn.active,.filter-btn:hover{border-color:var(--or);color:var(--or)}
.gallery-grid{columns:4;column-gap:10px}
@media(max-width:900px){.gallery-grid{columns:3}}
@media(max-width:600px){.gallery-grid{columns:2}}
</style>

<div class="page-hero">
  <p class="page-hero__label">Gallery</p>
  <h1 class="page-hero__title">30 glances,<br><em style="font-style:italic;color:var(--or)">30 stories</em></h1>
  <p class="page-hero__desc">From newborns to adults, first snowfalls to adoptions — life at Cimes Blanches in pictures.</p>
</div>

<section class="section">
  <div class="container">
    <div class="gallery-filters reveal">
      <button class="filter-btn active" data-filter="all">All</button>
      <button class="filter-btn" data-filter="chiots">🐾 Puppies</button>
      <button class="filter-btn" data-filter="pomsky">Pomsky</button>
      <button class="filter-btn" data-filter="pomeranian">Pomeranian</button>
      <button class="filter-btn" data-filter="husky">Husky</button>
      <button class="filter-btn" data-filter="famille">Families</button>
      <button class="filter-btn" data-filter="nature">Nature & Alps</button>
    </div>
    <div class="gallery-grid reveal">
      {% for photo in collections.galerie %}
      <div class="gallery-item" data-cat="{{ photo.data.categorie }}">
        <img src="{{ photo.data.image }}" alt="{{ photo.data.legende_en }}">
        <div class="gallery-item__caption">{{ photo.data.legende_en }}</div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<script>
document.querySelectorAll('.filter-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    const f = btn.dataset.filter;
    document.querySelectorAll('.gallery-item').forEach(item => {
      item.style.display = (f === 'all' || item.dataset.cat.includes(f)) ? '' : 'none';
    });
  });
});
</script>
