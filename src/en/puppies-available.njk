---
layout: layouts/base.njk
lang: en
title: "Available Puppies — Pomsky, Pomeranian, Husky — Cimes Blanches Kennel"
description: "Puppies available for adoption: Pomsky, Pomeranian and Siberian Husky in Sierre, Valais Switzerland. FCI pedigree, vaccinated, microchipped."
permalink: "/en/puppies-available.html"
hreflang_fr: "/chiots-disponibles.html"
hreflang_en: "/en/puppies-available.html"
---
<style>
.filter-race{display:flex;gap:.8rem;flex-wrap:wrap;margin-bottom:2.5rem}
.filter-race button{padding:.45rem 1.1rem;font-family:var(--sans);font-size:.72rem;letter-spacing:.1em;text-transform:uppercase;border:1px solid var(--gris-clair);border-radius:20px;background:transparent;color:var(--gris);cursor:pointer;transition:all .2s}
.filter-race button.active,.filter-race button:hover{border-color:var(--or);color:var(--or)}
.chiot-detail-list{list-style:none;margin:.6rem 0 1rem}
.chiot-detail-list li{font-size:.82rem;color:var(--gris);padding:.25rem 0;display:flex;gap:.5rem}
.chiot-detail-list li::before{content:'—';color:var(--or);flex-shrink:0}
.cta-block{background:linear-gradient(135deg,#F8F3E8,#F0EDE6);border:1px solid rgba(201,168,76,.2);border-radius:var(--radius);padding:3rem;text-align:center;margin-top:4rem}
.cta-block h3{font-family:var(--serif);font-size:1.6rem;font-weight:300;margin-bottom:.8rem}
.cta-block p{color:var(--gris);font-size:.95rem;margin-bottom:1.8rem}
</style>

<div class="page-hero">
  <p class="page-hero__label">Ready for adoption</p>
  <h1 class="page-hero__title">Available <em style="font-style:italic;color:var(--or)">puppies</em></h1>
  <p class="page-hero__desc">Every puppy leaves with FCI pedigree, health record, vaccines, microchip and a welcome kit.</p>
</div>

<section class="section">
  <div class="container">
    <div class="filter-race reveal">
      <button class="active" data-race="tous">All breeds</button>
      <button data-race="pomsky">Pomsky</button>
      <button data-race="pomeranian">Pomeranian</button>
      <button data-race="husky">Husky</button>
      <button data-race="disponible">🟢 Available only</button>
    </div>
    <div class="chiots-grid reveal">
      {% for chiot in collections.chiots %}
      <div class="chiot-card" data-race="{{ chiot.data.race }}" data-statut="{{ chiot.data.statut }}">
        <div class="chiot-card__img"><img src="{{ chiot.data.photo }}" alt="{{ chiot.data.nom }} — {{ chiot.data.sous_titre_en }}" loading="lazy"></div>
        <div class="chiot-card__body">
          {% if chiot.data.statut == "disponible" %}<span class="chiot-card__badge badge--dispo">Available</span>{% else %}<span class="chiot-card__badge badge--reserve">Reserved</span>{% endif %}
          <h2 class="chiot-card__name">{{ chiot.data.nom }}</h2>
          <div class="chiot-card__meta"><span>{{ chiot.data.sous_titre_en }}</span><span>{{ chiot.data.age_en }}</span></div>
          <ul class="chiot-detail-list">
            {% for atout in chiot.data.atouts_en | lignes %}<li>{{ atout }}</li>{% endfor %}
          </ul>
          <div class="chiot-card__price">CHF {{ chiot.data.prix | prixCH }}</div>
          {% if chiot.data.statut == "disponible" %}
          <a href="contact.html" class="btn-primary" style="margin-top:1rem;width:100%;justify-content:center;font-size:.72rem">Reserve {{ chiot.data.nom }} →</a>
          {% else %}
          <a href="contact.html" class="btn-secondary" style="margin-top:1rem;width:100%;justify-content:center;font-size:.72rem">Join waiting list</a>
          {% endif %}
        </div>
      </div>
      {% endfor %}
    </div>
    <div class="cta-block reveal">
      <h3>Can't find your perfect match?</h3>
      <p>Join our waiting list — we contact you first when a puppy matching your criteria becomes available.</p>
      <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap">
        <a href="contact.html" class="btn-primary">Join the waiting list →</a>
        <a href="adoption-process.html" class="btn-secondary">Adoption process</a>
      </div>
    </div>
  </div>
</section>

<script>
document.querySelectorAll('.filter-race button').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.filter-race button').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    const race = btn.dataset.race;
    document.querySelectorAll('.chiot-card').forEach(card => {
      if (race === 'tous') { card.style.display = ''; return; }
      if (race === 'disponible') { card.style.display = card.dataset.statut === 'disponible' ? '' : 'none'; return; }
      card.style.display = card.dataset.race === race ? '' : 'none';
    });
  });
});
</script>
