      <div class="footer-brand">
        <div class="nav__logo">{{ site.nom }}<span>{{ site.localite }}</span></div>
        <p>{% if L == "fr" %}Élevage familial de Pomsky, Pomeranian et Husky sibérien dans les Alpes valaisannes.{% else %}Family kennel breeding Pomsky, Pomeranian and Siberian Husky in the Swiss Alps.{% endif %}</p>
      </div>
