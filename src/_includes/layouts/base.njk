{%- set L = lang or "fr" -%}
<!DOCTYPE html>
<html lang="{{ L }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }}</title>
  <meta name="description" content="{{ description }}">
  {% if keywords %}<meta name="keywords" content="{{ keywords }}">{% endif %}
  {% if hreflang_fr %}<link rel="alternate" hreflang="fr" href="{{ hreflang_fr }}">{% endif %}
  {% if hreflang_en %}<link rel="alternate" hreflang="en" href="{{ hreflang_en }}">{% endif %}
  {% if hreflang_fr %}<link rel="alternate" hreflang="x-default" href="{{ hreflang_fr }}">{% endif %}
  <link rel="stylesheet" href="{{ '/css/style.css' if L == 'fr' else '../css/style.css' }}">
  <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
</head>
<body>
<div class="progress-bar"></div>

{% include "partials/nav.njk" %}

{{ content | safe }}

{% include "partials/footer.njk" %}

<div class="lightbox" role="dialog" aria-modal="true" aria-label="Photo">
  <button class="lightbox__close" aria-label="Fermer">✕</button>
  <img class="lightbox__img" src="" alt="">
</div>

<div class="pom-runner" aria-hidden="true">
  <svg width="90" height="90" viewBox="0 0 90 90" fill="none" xmlns="http://www.w3.org/2000/svg"><ellipse cx="45" cy="52" rx="22" ry="16" fill="#E8BF6A"/><circle cx="62" cy="38" r="14" fill="#E8BF6A"/><ellipse cx="70" cy="41" rx="7" ry="5" fill="#F5D48A"/><ellipse cx="73" cy="40" rx="2.5" ry="1.8" fill="#2A1A0A"/><circle cx="65" cy="35" r="3" fill="#fff"/><circle cx="65" cy="35" r="1.8" fill="#2A1A0A"/><circle cx="65.8" cy="34.2" r="0.7" fill="#fff"/><polygon points="54,28 58,18 63,28" fill="#C9A040"/><polygon points="63,28 68,18 72,28" fill="#C9A040"/><ellipse cx="24" cy="42" rx="10" ry="7" fill="#C9A040" transform="rotate(-30 24 42)"/><ellipse cx="20" cy="38" rx="7" ry="5" fill="#E8BF6A" transform="rotate(-30 20 38)"/><rect x="33" y="64" width="6" height="12" rx="3" fill="#C9A040" transform="rotate(-15 33 64)"/><rect x="44" y="65" width="6" height="11" rx="3" fill="#C9A040" transform="rotate(10 44 65)"/><rect x="55" y="64" width="6" height="12" rx="3" fill="#C9A040" transform="rotate(-10 55 64)"/><rect x="64" y="63" width="6" height="11" rx="3" fill="#C9A040" transform="rotate(15 64 63)"/><path d="M67 43 Q70 46 73 43" stroke="#2A1A0A" stroke-width="1.2" stroke-linecap="round" fill="none"/><ellipse cx="70" cy="46" rx="2" ry="2.5" fill="#E85555"/></svg>
</div>

<script src="{{ '/js/main.js' if L == 'fr' else '../js/main.js' }}"></script>
<script>
  // Redirige vers l'admin apres connexion via le widget Identity (invitation CMS)
  if (window.netlifyIdentity) {
    window.netlifyIdentity.on("init", user => {
      if (!user) {
        window.netlifyIdentity.on("login", () => {
          document.location.href = "{{ '/admin/' if L == 'fr' else '../admin/' }}";
        });
      }
    });
  }
</script>
</body>
</html>
